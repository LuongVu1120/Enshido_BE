# ─── Database ──────────────────────────────────────────────────────────────
# DEV (zero-infra, mặc định): SQLite. Không cần Docker/Postgres.
DATABASE_PROVIDER=sqlite
DATABASE_URL="file:./dev.db"

# PROD: PostgreSQL (bật docker-compose). Đổi DATABASE_PROVIDER=postgresql và:
# DATABASE_URL="postgresql://enshido:enshido@localhost:5432/enshido?schema=public"

# ─── Auth ──────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="900s"
JWT_REFRESH_TTL="7d"

# ─── API ───────────────────────────────────────────────────────────────────
API_PORT=4000
WEB_ORIGIN="http://localhost:3000"

# ─── Storage (ảnh, file) ───────────────────────────────────────────────────
# DEV: disk (./uploads). PROD: s3
STORAGE_DRIVER=disk
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="enshido"
S3_ACCESS_KEY="enshido"
S3_SECRET_KEY="enshido123"

# ─── Redis (cache/queue/ws adapter) — tùy chọn ở dev ───────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Business rules ────────────────────────────────────────────────────────
DEFAULT_ALLOWED_LOSS_PERCENT=3.0

# ─── Web ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"
