# ─── Database ──────────────────────────────────────────────────────────────
# PostgreSQL (Supabase). Xem prisma/schema.prisma.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<pooler-host>:6543/postgres?schema=public&pgbouncer=true"
# Dùng cho `prisma migrate` (transaction pooler ở trên không hỗ trợ advisory lock).
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres?schema=public"

# ─── Auth ──────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="900s"
JWT_REFRESH_TTL="7d"

# ─── API ───────────────────────────────────────────────────────────────────
API_PORT=4000
WEB_ORIGIN="http://localhost:3000"

# ─── Storage (ảnh, file) ───────────────────────────────────────────────────
STORAGE_DRIVER=disk

# ─── Business rules ────────────────────────────────────────────────────────
DEFAULT_ALLOWED_LOSS_PERCENT=3.0
