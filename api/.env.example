# Copy file này thành api/.env trước khi chạy: cp api/.env.example api/.env
# Dev mặc định — SQLite, zero-infra.
DATABASE_URL="file:./dev.db"
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="900s"
JWT_REFRESH_TTL="7d"
API_PORT=4000
WEB_ORIGIN="http://localhost:3000"
# QR phiếu (Phase 013): URL nhúng vào QR để quét từ điện thoại/app ngoài.
# Bỏ trống → tự dò IP LAN khi WEB_ORIGIN là localhost. Đặt để ghi đè (domain/IP cố định):
# PUBLIC_WEB_ORIGIN="http://192.168.1.50:3000"
STORAGE_DRIVER=disk
DEFAULT_ALLOWED_LOSS_PERCENT=3.0

# PROD: đổi sang PostgreSQL + sửa provider trong prisma/schema.prisma = "postgresql"
# DATABASE_URL="postgresql://enshido:enshido@localhost:5432/enshido?schema=public"
