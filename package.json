{
  "name": "enshido",
  "version": "0.1.0",
  "private": true,
  "description": "ENSHIDO Jewelry — Phần mềm quản lý đơn hàng sản xuất xưởng kim hoàn (MVP Core)",
  "workspaces": [
    "packages/*",
    "api"
  ],
  "scripts": {
    "dev": "npm run dev -w api",
    "dev:api": "npm run dev -w api",
    "build": "npm run build -w @enshido/types && npm run build -w api",
    "db:generate": "npm run prisma:generate -w api",
    "db:migrate": "npm run prisma:migrate -w api",
    "db:seed": "npm run prisma:seed -w api",
    "db:reset": "npm run prisma:reset -w api",
    "test": "npm run test -w api",
    "selftest": "npm run selftest -w api"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
